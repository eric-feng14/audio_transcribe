# Copy this file to ".env" and fill in your values.
# run.py / summarize.py load .env automatically (or set these in your shell).

# Anthropic API key for the summarize step. Get one at https://console.anthropic.com
# Only needed if you want LLM summaries (run without summaries via --no-summarize).
ANTHROPIC_API_KEY=your-api-key-here

# --- Optional overrides (defaults shown; usually leave these alone) ---

# Whisper model: large-v3 (best) | medium | small | base | tiny (smaller = faster, less accurate)
# WHISPER_MODEL=large-v3

# Transcription device: auto (detect GPU) | cuda (force NVIDIA GPU) | cpu (force CPU)
# WHISPER_DEVICE=auto

# Anthropic model used for summaries.
# CLAUDE_MODEL=claude-sonnet-4-6
